// Phase 2 delivery pipeline, one per service. It reuses the gated pipeline
// from Project 5 and adds: publish the jar to Nexus (the artifact store), and
// deploy with Helm instead of by hand.
//
// Create one Jenkins job per service and set SERVICE to catalog, orders, or
// notifications. The storefront has its own simpler build (npm + docker).

pipeline {
    agent any

    triggers {
        githubPush()
    }

    parameters {
        choice(name: 'SERVICE', choices: ['catalog', 'orders', 'notifications'], description: 'Which service to build')
        string(name: 'SONAR_HOST', defaultValue: 'http://100.51.104.230:9000', description: 'SonarQube URL reachable from Jenkins executor')
        string(name: 'NEXUS_URL', defaultValue: 'http://100.51.104.230:8081/repository/maven-releases/', description: 'Nexus repository URL reachable from Jenkins executor')
    }

    environment {
        AWS_REGION   = 'us-east-1'
        ECR_ACCOUNT  = '922685583704'
        EKS_CLUSTER  = 'shopflow'

        SERVICE_DIR  = "services/${params.SERVICE}-service"
        IMAGE_REPO   = "shopflow-${params.SERVICE}"
        IMAGE_TAG    = "${BUILD_NUMBER}"
        ECR_REGISTRY = "${ECR_ACCOUNT}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        IMAGE        = "${ECR_REGISTRY}/${IMAGE_REPO}"

        SONAR_HOST   = "${params.SONAR_HOST ?: 'http://100.51.104.230:9000'}"
        NEXUS_URL    = "${params.NEXUS_URL ?: 'http://100.51.104.230:8081/repository/maven-releases/'}"

        TRIVY_CACHE_DIR = '/var/jenkins_home/.cache/trivy/global'

        AWS_CREDS    = credentials('aws-ecr')
        SONAR_TOKEN  = credentials('sonar-token')
        NEXUS_CREDS  = credentials('nexus')
    }

    stages {
        stage('Checkout') { steps { checkout scm } }

        stage('Resolve Service') {
            steps {
                sh 'echo "SERVICE=${SERVICE}"'
                sh 'echo "SERVICE_DIR=${SERVICE_DIR}"'
            }
        }

        stage('Clean workspace and caches') {
            steps {
                sh '''
                    set -e
                    rm -rf ${SERVICE_DIR}/target ${SERVICE_DIR}/.scannerwork
                    rm -rf /tmp/sonar-status.json
                    rm -rf /tmp/trivy-${SERVICE}-${BUILD_NUMBER} /tmp/trivy-cache-${SERVICE}-${BUILD_NUMBER}

                    # Keep one shared Trivy cache for all services to avoid duplicate DB copies.
                    mkdir -p ${TRIVY_CACHE_DIR}

                    # Run aggressive cleanup when free space is low on the cache filesystem.
                    FREE_KB=$(df -Pk /var/jenkins_home | awk 'NR==2 {print $4}')
                    MIN_FREE_KB=6291456
                    if [ "${FREE_KB}" -lt "${MIN_FREE_KB}" ]; then
                        echo "Low disk on /var/jenkins_home detected (${FREE_KB} KB free). Running deep cleanup..."
                        rm -rf /tmp/trivy-* /tmp/sonar-* || true
                        trivy clean --scan-cache || true
                        docker builder prune -af || true
                        docker image prune -af || true
                        docker container prune -f || true
                    else
                        docker builder prune -f || true
                    fi
                '''
            }
        }

        stage('Build') { steps { dir("${SERVICE_DIR}") { sh 'mvn -B -ntp clean compile' } } }

        stage('Test + Coverage') {
            steps { dir("${SERVICE_DIR}") { sh 'mvn -B -ntp test' } }
            post {
                always {
                    junit testResults: "${SERVICE_DIR}/target/surefire-reports/*.xml", allowEmptyResults: true
                }
            }
        }

        stage('Code Analysis (SonarQube)') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh '''
                        SONAR_URL="${SONAR_HOST}"
                        SONAR_PROJECT_KEY="shopflow-${SERVICE}"
                        SONAR_PROJECT_NAME="shopflow-${SERVICE}"
                        echo "Using SonarQube URL: ${SONAR_URL}"
                        echo "Resolved SONAR_HOST=${SONAR_HOST}"
                        curl -fsS "${SONAR_URL}/api/system/status" > /tmp/sonar-status.json \
                          || { echo "SonarQube is not reachable at ${SONAR_URL} from the Jenkins executor"; exit 1; }

                        echo "Checking SonarQube project ${SONAR_PROJECT_KEY}..."
                        SEARCH_HTTP_CODE=$(curl -sS -u "${SONAR_TOKEN}:" -o /tmp/sonar-projects.json -w "%{http_code}" "${SONAR_URL}/api/projects/search?projects=${SONAR_PROJECT_KEY}" || true)
                        if [ "${SEARCH_HTTP_CODE}" = "401" ]; then
                            echo "Sonar token is not valid for API authentication (401). Check Jenkins credential sonar-token."
                            exit 1
                        fi
                        if [ "${SEARCH_HTTP_CODE}" = "403" ]; then
                            echo "Sonar token is authenticated but cannot browse projects (403). Skipping project pre-check and continuing with scanner."
                        elif [ "${SEARCH_HTTP_CODE}" != "200" ]; then
                            echo "Unable to query SonarQube projects (HTTP ${SEARCH_HTTP_CODE}); verify token and network access."
                            exit 1
                        elif ! grep -q "\"key\":\"${SONAR_PROJECT_KEY}\"" /tmp/sonar-projects.json; then
                            echo "SonarQube project ${SONAR_PROJECT_KEY} does not exist yet. Creating it with the configured credentials..."
                            CREATE_HTTP_CODE=$(curl -sS -u "${SONAR_TOKEN}:" -X POST -o /tmp/sonar-create.json -w "%{http_code}" "${SONAR_URL}/api/projects/create?name=${SONAR_PROJECT_NAME}&project=${SONAR_PROJECT_KEY}" || true)
                            if [ "${CREATE_HTTP_CODE}" != "200" ]; then
                                echo "Could not create SonarQube project ${SONAR_PROJECT_KEY} (HTTP ${CREATE_HTTP_CODE})."
                                echo "Create it manually in SonarQube or use a token/user with Create Project permission."
                                exit 1
                            fi
                        fi

                        mvn -B -ntp org.sonarsource.scanner.maven:sonar-maven-plugin:5.7.0.6970:sonar \
                          -Dsonar.host.url=${SONAR_URL} \
                          -Dsonar.token=${SONAR_TOKEN} \
                          -Dsonar.projectKey=${SONAR_PROJECT_KEY} \
                          -Dsonar.projectName=${SONAR_PROJECT_NAME} \
                          -Dsonar.qualitygate.wait=true \
                          -Dsonar.qualitygate.timeout=300 || {
                            echo "Sonar analysis was rejected by SonarQube. Check that the Jenkins token has permission to analyze the project and that the project exists or can be created.";
                            exit 1;
                        }
                    '''
                }
            }
        }

        stage('Dependency Scan (Trivy)') {
            steps { sh "trivy fs --scanners vuln --severity HIGH,CRITICAL --ignore-unfixed --exit-code 1 --no-progress ${SERVICE_DIR}" }
        }

        stage('Package') { steps { dir("${SERVICE_DIR}") { sh 'mvn -B -ntp package -DskipTests' } } }

        stage('Publish artifact to Nexus') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh '''
                        NEXUS_REPO_URL="${NEXUS_URL}"
                        echo "Using Nexus URL: ${NEXUS_REPO_URL}"
                        export NEXUS_USERNAME=${NEXUS_CREDS_USR}
                        export NEXUS_PASSWORD=${NEXUS_CREDS_PSW}
                        mvn -B -ntp deploy:deploy-file \
                          -s ../../cicd/settings-nexus.xml \
                          -Durl=${NEXUS_REPO_URL} \
                          -DrepositoryId=nexus \
                          -Dfile=target/app.jar \
                          -DgroupId=com.shopflow -DartifactId=${SERVICE}-service -Dversion=1.0.${BUILD_NUMBER} -Dpackaging=jar
                    '''
                }
            }
        }

        stage('Docker Build') { steps { dir("${SERVICE_DIR}") { sh 'docker build -t ${IMAGE}:${IMAGE_TAG} -t ${IMAGE}:latest .' } } }

        stage('Image Scan (Trivy)') {
            steps {
                sh '''
                    rm -rf /tmp/trivy-${SERVICE}-${BUILD_NUMBER}
                    mkdir -p ${TRIVY_CACHE_DIR}

                    FREE_KB=$(df -Pk /var/jenkins_home | awk 'NR==2 {print $4}')
                    MIN_FREE_KB=5242880
                    if [ "${FREE_KB}" -lt "${MIN_FREE_KB}" ]; then
                        echo "Low disk before image scan (${FREE_KB} KB free). Pruning local Docker and scan cache..."
                        trivy clean --scan-cache || true
                                                docker image prune -f || true
                                                docker builder prune -f || true
                    fi

                                        docker image inspect ${IMAGE}:${IMAGE_TAG} > /dev/null \
                                            || { echo "Image ${IMAGE}:${IMAGE_TAG} is missing before Trivy scan"; exit 1; }

                    export TRIVY_SKIP_DB_UPDATE=false
                    trivy image --scanners vuln --severity CRITICAL --ignore-unfixed --exit-code 1 --no-progress --cache-dir ${TRIVY_CACHE_DIR} ${IMAGE}:${IMAGE_TAG}
                '''
            }
        }

        stage('Push to ECR') {
            steps {
                sh '''
                    export AWS_ACCESS_KEY_ID=$AWS_CREDS_USR
                    export AWS_SECRET_ACCESS_KEY=$AWS_CREDS_PSW
                    aws ecr describe-repositories --region ${AWS_REGION} --repository-names ${IMAGE_REPO} \
                      || aws ecr create-repository --region ${AWS_REGION} --repository-name ${IMAGE_REPO}
                    aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${ECR_REGISTRY}
                    docker push ${IMAGE}:${IMAGE_TAG}
                    docker push ${IMAGE}:latest

                    # Free host storage after push; registry already stores image artifacts.
                    docker rmi ${IMAGE}:${IMAGE_TAG} ${IMAGE}:latest || true
                '''
            }
        }

        stage('Deploy with Helm') {
            steps {
                sh '''
                    export AWS_ACCESS_KEY_ID=$AWS_CREDS_USR
                    export AWS_SECRET_ACCESS_KEY=$AWS_CREDS_PSW
                    aws eks update-kubeconfig --region ${AWS_REGION} --name ${EKS_CLUSTER}
                    kubectl get configmap shopflow-config -n default >/dev/null 2>&1 || true
                    if kubectl get configmap shopflow-config -n default >/dev/null 2>&1; then
                        echo "Repairing Helm ownership metadata on existing shopflow-config ConfigMap..."
                        kubectl label configmap shopflow-config -n default app.kubernetes.io/managed-by=Helm --overwrite
                        kubectl annotate configmap shopflow-config -n default meta.helm.sh/release-name=shopflow meta.helm.sh/release-namespace=default --overwrite
                    fi
                                        for i in 1 2 3; do
                                            helm upgrade --install shopflow helm/shopflow \
                                                --namespace default \
                                                --reuse-values \
                                                --set-string image.tags.${SERVICE}=${IMAGE_TAG} \
                                                --force \
                                                --wait=false \
                                                && break
                                            if [ "$i" -eq 3 ]; then
                                                exit 1
                                            fi
                                            echo "Helm deploy attempt $i failed, retrying..."
                                            sleep 8
                                        done
                    kubectl rollout status deployment/${SERVICE}-service --timeout=180s
                '''
            }
        }
    }

    post {
        success { echo "Deployed ${IMAGE}:${IMAGE_TAG} to ${EKS_CLUSTER}." }
        failure { echo 'A stage or gate failed. Read the first red error above.' }
    }
}
